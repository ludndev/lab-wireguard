{
  "name": "wg-portal-client",
  "version": "1.0.0",
  "description": "TypeScript client for the WireGuard Portal v2 REST API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"]
  },
  "keywords": [
    "wireguard",
    "wg-portal",
    "vpn",
    "api-client"
  ],
  "author": {
    "name": "Judicaël AHYI (ludndev)",
    "email": "ludndev@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
