{
    "name": "wg-portal/client",
    "description": "PHP client for the WireGuard Portal v2 REST API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Judicaël AHYI (ludndev)",
            "email": "ludndev@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "WgPortal\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WgPortal\\Client\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true
    }
}
