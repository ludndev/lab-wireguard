# WireGuard + wg-portal Configuration
# Copy this to .env and customize for your environment

# Admin credentials for wg-portal
# Password must be >= 16 characters (auth.min_password_length requirement)
WG_ADMIN_USER=admin@wgportal.local
WG_ADMIN_PASSWORD=Sup3rSecret-Admin-Pw!

# REST API authentication token
# Must be set for the /api/v1/* endpoints to be enabled
WG_API_TOKEN=dev-test-api-token-please-change

# Container and network settings
WG_PORTAL_CONTAINER=wg-portal
WG_SEEDER_CONTAINER=wg-seeder
WG_TEST_CONTAINER=wg-test
WG_NETWORK=wgnet

# Port and host settings
# WG_WEB_HOST: bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
# WG_EXTERNAL_HOST: public hostname or IP used in URLs and WebAuthn RPID
WG_WEB_HOST=0.0.0.0
WG_EXTERNAL_HOST=localhost
WG_WEB_PORT=8888

# WireGuard interface ports
# wg0 = system network  | wg1 = backoffice network
WG_WG0_PORT=51820
WG_WG1_PORT=51821

# LAN network CIDRs assigned to each WireGuard interface
# wg0 (system)     peers get addresses from 10.10.0.0/24, server is 10.10.0.1
# wg1 (backoffice) peers get addresses from 10.20.0.0/24, server is 10.20.0.1
WG_WG0_CIDR=10.10.0.0/24
WG_WG1_CIDR=10.20.0.0/24

# Test configuration
# How the test peer reaches the server (on the docker compose network)
WG_TEST_ENDPOINT=wg-portal:51820
